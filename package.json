{
	"name": "claude-code-pi",
	"private": true,
	"version": "0.0.0",
	"description": "A next-generation coding CLI built on pi-mono",
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "npm run build --workspaces",
		"check": "npm run check:lint && npm run check:format && npm run check:types",
		"check:lint": "biome lint packages/",
		"check:format": "biome format --check packages/",
		"check:types": "tsc --build",
		"test": "vitest run",
		"prepare": "husky"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"husky": "^9.1.7",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	}
}
