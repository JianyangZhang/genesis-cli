{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"baseUrl": ".",
		"paths": {
			"@mariozechner/pi-ai": ["packages/pi-ai/src/index.ts"],
			"@pickle-pee/genesis-cli": ["packages/app-cli/src/index.ts"],
			"@pickle-pee/config": ["packages/app-config/src/index.ts"],
			"@pickle-pee/evaluation": ["packages/app-evaluation/src/index.ts"],
			"@pickle-pee/extensions": ["packages/app-extensions/src/index.ts"],
			"@pickle-pee/kernel": ["packages/kernel/src/index.ts"],
			"@pickle-pee/pi-ai": ["packages/pi-ai/src/index.ts"],
			"@pickle-pee/runtime": ["packages/app-runtime/src/index.ts"],
			"@pickle-pee/tui-core": ["packages/app-tui-core/src/index.ts"],
			"@pickle-pee/tools": ["packages/app-tools/src/index.ts"],
			"@pickle-pee/ui": ["packages/app-ui/src/index.ts"]
		},
		"strict": true,
		"declaration": true,
		"sourceMap": true,
		"composite": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true
	}
}
